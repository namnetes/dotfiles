    export BROWSER="/mnt/c/Program Files (x86)/Microsoft/Edge/Application/msedge.exe"
fi

function jl() { # to start jupyter lab sandbox environment
    ve "$SANDBOX_HOME"
    jupyter lab
    deactivate
    cd "$HOME" || return
}

function ipy() { # to start ipython in the sandbox environment
    ve "$SANDBOX_HOME"
    ipython
    deactivate
    cd "$HOME" || return
}

